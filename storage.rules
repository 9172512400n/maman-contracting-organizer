rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isImage() {
      return request.resource != null && request.resource.contentType.matches('image/.*');
    }

    function isPdf() {
      return request.resource != null && request.resource.contentType == 'application/pdf';
    }

    match /jobs/permit-docs/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        request.resource.size < 15 * 1024 * 1024 &&
        (isImage() || isPdf());
    }

    match /permits/documents/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        request.resource.size < 15 * 1024 * 1024 &&
        (isImage() || isPdf());
    }

    match /contacts/photos/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        request.resource.size < 10 * 1024 * 1024 &&
        isImage();
    }

    match /contacts/business-cards/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() &&
        request.resource.size < 10 * 1024 * 1024 &&
        (isImage() || isPdf());
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
