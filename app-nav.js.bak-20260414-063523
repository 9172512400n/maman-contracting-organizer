      try {
        const path = 'permits/' + Date.now() + '_' + file.name.replace(/[^a-zA-Z0-9._-]/g, '_');
        const url = await uploadToStorage(file, path);
        window._uploadedPermitDocUrls.push({ name: file.name, url });
