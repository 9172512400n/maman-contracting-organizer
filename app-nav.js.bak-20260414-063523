      let norm = t.toLowerCase();
      Object.keys(wordMap).sort((a,b)=>b.length-a.length).forEach(w=>{ norm=norm.replace(new RegExp('\\b'+w+'\\b','g'),wordMap[w]); });
      const nums = norm.match(/\d+\.?\d*/g);
